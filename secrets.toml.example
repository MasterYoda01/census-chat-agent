# Paste this into Streamlit Cloud → App Settings → Secrets
# (Settings > Secrets in your deployed app dashboard)
# These become available as os.environ / st.secrets

SNOWFLAKE_ACCOUNT = "your_account_identifier"
SNOWFLAKE_USER = "your_user"
SNOWFLAKE_PASSWORD = "your_password"
SNOWFLAKE_WAREHOUSE = "your_warehouse"
SNOWFLAKE_DATABASE = "US_OPEN_CENSUS_DATA__NEIGHBORHOOD_INSIGHTS__FREE_DATASET"
SNOWFLAKE_SCHEMA = "PUBLIC"
ANTHROPIC_API_KEY = "sk-ant-..."
